# =============================================
# Переменные окружения для приложения
# =============================================

# Порт, на котором запускается сервер
# На Render задаётся автоматически — здесь не трогайте
PORT=5000

# =============================================
# GigaChat (Сбер)
# =============================================

# Ключ авторизации (Authorization key) из личного кабинета GigaChat
# Получить: https://developers.sber.ru/studio/workspaces/
# Это base64-строка вида ZjA3MmNiNDgtZDQwOC00...
GIGACHAT_AUTH_KEY=

# Тип доступа — для физлиц обычно GIGACHAT_API_PERS
# Для юрлиц: GIGACHAT_API_B2B или GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Модель: GigaChat | GigaChat-Pro | GigaChat-Max
# Базовая GigaChat — самая быстрая и дешёвая, для подбора аналогов её достаточно
GIGACHAT_MODEL=GigaChat
